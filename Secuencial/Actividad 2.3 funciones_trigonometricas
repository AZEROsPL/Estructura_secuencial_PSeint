Algoritmo funciones_trigonometricas
	Definir numero, seno, coseno, tangente, raiz0, logaritmoNatural Como Real
	Imprimir "Ingrese un número: "
	Leer numero
	seno = sen(numero)
	coseno = cos(numero)
	tangente = tan(numero)
	raiz0 = raiz(numero)
	logaritmoNatural = ln(numero)
	Imprimir "Del número ", numero
	Imprimir "Su seno es ", seno
	Imprimir "Su coseno es ", coseno
	Imprimir "Su tangente es ", tangente
	Imprimir "Su raíz cuadrad es ", raiz0
	Imprimir "Su logaritmo natural es ", logaritmoNatural
	Imprimir "Y su logaritmo en base 10 es ", logaritmoNatural/ln(10)
FinAlgoritmo