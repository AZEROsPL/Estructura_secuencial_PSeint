Algoritmo promedio_arigmetico
	Definir n1, n2, n3, promedio Como Real
	Imprimir "Introduce el primer número: "
	leer n1
	Imprimir "Introduce el segundo número: "
	Leer n2
	Imprimir "Introduce el tercer número: "
	Leer n3
	promedio = (n1+n2+n3)/3
	Imprimir "El promedio de los tres números es: ", promedio
FinAlgoritmo
